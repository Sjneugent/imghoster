SESSION_SECRET=replace_with_a_long_random_string_in_production
PORT=3000
NODE_ENV=production
DB_PATH=./data/imghoster.db

# ── Storage provider ──────────────────────────────────────────────────────────
# Which storage backend to use for image files.
# Values: local | s3 | azure | gcs | dbblob | replicated (default: local)
STORAGE_PROVIDER=local

# ── Local disk / NFS mount ────────────────────────────────────────────────────
# Directory to store image files when STORAGE_PROVIDER=local.
STORAGE_LOCAL_DIR=../uploads

# Legacy alias (still supported for backward compatibility)
# IMAGE_STORAGE_MODE=file   # or "blob" / "dbblob" for database blobs
UPLOADS_DIR=../uploads

# ── Amazon S3 / MinIO / any S3-compatible store ───────────────────────────────
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
# Leave blank for AWS; set to MinIO/Ceph/B2/R2 URL for self-hosted
STORAGE_S3_ENDPOINT=
# Set "true" for MinIO or other path-style endpoints
STORAGE_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
STORAGE_AZURE_ACCOUNT=
STORAGE_AZURE_KEY=
STORAGE_AZURE_CONTAINER=images

# ── Google Cloud Storage ──────────────────────────────────────────────────────
STORAGE_GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/keyfile.json
STORAGE_GCS_PROJECT=

# ── CDN / presigned URL delivery ─────────────────────────────────────────────
# If set, /i/:slug returns a 302 redirect to this URL + "/" + filename
# instead of streaming the image through Node.
STORAGE_CDN_BASE_URL=
STORAGE_CDN_TTL_SECONDS=86400

# ── Replication (STORAGE_PROVIDER=replicated) ─────────────────────────────────
# Comma-separated list of providers: write to all, read from first healthy one.
STORAGE_PROVIDERS=s3,local
# Minimum number of providers that must succeed on each write.
STORAGE_WRITE_QUORUM=1
# Health-check polling interval in milliseconds (0 = disable).
STORAGE_HEALTH_CHECK_INTERVAL_MS=30000

# Session cookie transport security:
# true  = only send cookie over HTTPS (recommended for production)
# false = allow HTTP (local/dev only)
# auto  = secure on HTTPS, works on local HTTP
COOKIE_SECURE=true

# Set to "false" to disable localhost authentication bypass.
# When enabled (default), requests from 127.0.0.1 / ::1 skip auth checks.
LOCALHOST_BYPASS=true

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ── Upload throttling ─────────────────────────────────────────────────────────
# Max image uploads per IP address per 15-minute window (default: 30).
UPLOAD_RATE_LIMIT_MAX=30

# Max image uploads per authenticated user per 15-minute window (default: 20).
USER_UPLOAD_RATE_LIMIT_MAX=20

# Max simultaneous in-flight upload requests from the same IP (default: 3).
MAX_CONCURRENT_UPLOADS=3
