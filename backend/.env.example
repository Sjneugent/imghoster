SESSION_SECRET=replace_with_a_long_random_string_in_production
PORT=3000
NODE_ENV=production
DB_PATH=./data/imghoster.db
IMAGE_STORAGE_MODE=file
UPLOADS_DIR=../uploads

# Session cookie transport security:
# true  = only send cookie over HTTPS (recommended for production)
# false = allow HTTP (local/dev only)
# auto  = secure on HTTPS, works on local HTTP
COOKIE_SECURE=true

# Set to "false" to disable localhost authentication bypass.
# When enabled (default), requests from 127.0.0.1 / ::1 skip auth checks.
LOCALHOST_BYPASS=true

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
