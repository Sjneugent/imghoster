{
  "name": "imghoster",
  "version": "1.0.0",
  "description": "Minimal personal image hosting backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:secure": "cross-env LOCALHOST_BYPASS=false node server.js",
    "dev": "node --watch server.js",
    "dev:secure": "cross-env LOCALHOST_BYPASS=false node --watch server.js",
    "seed": "node seed.js",
    "test": "node --test tests/api.test.js",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js",
    "db:migrate": "node scripts/db-migrate.js --reinit",
    "db:status": "node scripts/db-migrate.js --status",
    "db:export": "node scripts/db-replicate.js --export",
    "db:import": "node scripts/db-replicate.js --import",
    "db:replicate": "node scripts/db-replicate.js --migrate"
  },
  "dependencies": {
    "@hapi/bourne": "^3.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "express-session-better-sqlite3": "^1.2.1",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
