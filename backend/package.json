{
  "name": "imghoster",
  "version": "1.0.0",
  "description": "Minimal personal image hosting backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node server.js",
    "start:secure": "cross-env LOCALHOST_BYPASS=false node server.js",
    "dev": "tsc && node --watch server.js",
    "dev:secure": "cross-env LOCALHOST_BYPASS=false tsc && node --watch server.js",
    "seed": "tsc && node seed.js",
    "test": "tsc && node --test tests/api.test.js",
    "loadtest": "node scripts/loadtest.js",
    "db:backup": "tsc && node scripts/db-backup.js",
    "db:restore": "tsc && node scripts/db-restore.js",
    "db:migrate": "tsc && node scripts/db-migrate.js --reinit",
    "db:status": "tsc && node scripts/db-migrate.js --status",
    "db:export": "tsc && node scripts/db-replicate.js --export",
    "db:import": "tsc && node scripts/db-replicate.js --import",
    "db:replicate": "tsc && node scripts/db-replicate.js --migrate",
    "db:to-blobs": "node scripts/storage-migrate-to-blobs.js",
    "db:verify-blobs": "node scripts/storage-migrate-to-blobs.js --verify-only",
    "db:clear-blob-checkpoint": "node scripts/storage-migrate-to-blobs.js --clear-checkpoint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hapi/bourne": "^3.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "express-session-better-sqlite3": "^1.2.1",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "yazl": "^3.3.1"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/yazl": "^3.3.0",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
